# ==============================================================================
# .gitignore
# ------------------------------------------------------------------------------
# Enterprise .gitignore for the data platform project.
# Covers Python, data engineering artifacts, local secrets, logs, caches,
# notebooks, build outputs, Docker, Terraform, IDEs, quality reports and
# temporary runtime files.
# ============================================================================== 


# ==============================================================================
# PYTHON - BYTECODE / CACHE
# ==============================================================================
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.pytype/
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/
.nox/
.hypothesis/
.cache/
*.cover
*.py,cover
.pybuilder/
target/


# ==============================================================================
# PYTHON - PACKAGING / BUILD
# ==============================================================================
build/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
pip-wheel-metadata/
*.whl


# ==============================================================================
# VIRTUAL ENVIRONMENTS
# ==============================================================================
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
.virtualenv/
.python-version
pipenv.lock
Pipfile.lock
poetry.lock
pdm.lock
.pdm-python
.pdm-build/


# ==============================================================================
# ENVIRONMENT / SECRETS
# ==============================================================================
.env
.env.*
!.env.example
!.env.template
*.env
*.local.env
*.secret
*.secrets
secrets/
.secret/
.credentials/
credentials/
*.pem
*.key
*.crt
*.cer
*.p12
*.pfx
*.jks
*.keystore
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
*.kubeconfig
kubeconfig
service-account*.json
*gcp-key*.json
*aws-credentials*
*azure-credentials*


# ==============================================================================
# LOGS / RUNTIME
# ==============================================================================
logs/
log/
*.log
*.log.*
*.out
*.err
*.pid
*.pid.lock
*.seed
*.stackdump
runtime/
.run/
run/
tmp/
temp/
.tmp/
*.tmp
*.temp
*.swp
*.swo
*~


# ==============================================================================
# LOCAL DATA / STORAGE / LAKEHOUSE ARTIFACTS
# ==============================================================================
storage/
warehouse/
data_lake/
lakehouse/
checkpoints/
checkpoint/
dead_letter/
quarantine/
backups/
exports/
imports/
landing/
bronze/
silver/
gold/
raw/
processed/
curated/
archive/
archives/
*.checkpoint
*.crc
_SUCCESS
_committed_*
_started_*
_metadata
_delta_log/
.hoodie/
*.parquet
*.avro
*.orc
*.feather
*.arrow
*.csv
*.tsv
*.jsonl
*.ndjson
*.xlsx
*.xls
*.db
*.sqlite
*.sqlite3
*.duckdb
*.db-wal
*.db-shm


# Keep sample fixtures if intentionally versioned
!tests/fixtures/**
!examples/**
!samples/**
!docs/**/*.csv
!docs/**/*.json


# ==============================================================================
# QUALITY / VALIDATION / PROFILING OUTPUTS
# ==============================================================================
quality/reports/
quality/audit/
quality/dashboard/
quality/evidence/
quality/profiles/
quality/metrics/
reports/
profiling_reports/
validation_reports/
audit_reports/
coverage_reports/
schema/observed/
